{
  "expo": {
    "name": "Nyra",
    "slug": "healthpal",
    "scheme": "healthpal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.healthpal.app",
      "infoPlist": {
        "NSSupportsLiveActivities": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.healthpal.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-live-activity",
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#A8FF3E",
          "defaultChannel": "general"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Nyra needs access to your photos to analyze food from your gallery.",
          "cameraPermission": "Nyra needs access to your camera to snap and track your meals."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Nyra needs microphone access for voice conversations."
        }
      ]
    ],
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "LiveActivity",
                  "bundleIdentifier": "com.healthpal.app.LiveActivity",
                  "entitlements": {}
                }
              ]
            }
          }
        },
        "projectId": "ac14d039-082a-4fa6-9495-1da47f4ad261"
      },
      "router": {}
    },
    "owner": "rayanranaut"
  }
}
